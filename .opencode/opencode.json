{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "permission": {
    "task": {
      "*": "allow"
    },
    "bash": {
      "workspace/*": "allow",
      "/workspace/*": "allow",
      "*": "deny"
    },
    "write": {
      "workspace/*": "allow",
      "/workspace/*": "allow",
      "*": "deny"
    },
    "read": {
      "workspace/**": "allow",
      "/workspace/**": "allow",
      ".opencode/**": "allow"
    }
  },
  "agent": {
    "agent": {
      "description": "Primary autonomous agent - reads DIRECTIVE.md and manages tasks",
      "mode": "primary",
      "systemPromptFile": ".opencode/agents/agent.md",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "task": true
      }
    },
    "coder": {
      "description": "Specialized coding agent - builds on agent.md for coding tasks",
      "mode": "subagent",
      "systemPromptFile": ".opencode/agents/coder.md",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "task": true
      }
    },
    "judge": {
      "description": "Safety judge - validates actions before execution",
      "mode": "subagent",
      "systemPromptFile": ".opencode/subagents/judge.md",
      "task_budget": 20,
      "temperature": 0.1,
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "task": false
      }
    },
    "code-reviewer": {
      "description": "Security code reviewer - analyzes code for security vulnerabilities",
      "mode": "subagent",
      "systemPromptFile": ".opencode/subagents/code-reviewer.md",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "task": false
      }
    }
  }
}