{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "permission": {
    "task": {
      "*": "allow"
    },
    "bash": {
      "workspace/*": "allow",
      "/workspace/*": "allow",
      "*": "deny"
    },
    "write": {
      "workspace/*": "allow",
      "/workspace/*": "allow",
      "*": "deny"
    },
    "read": {
      "workspace/**": "allow",
      "/workspace/**": "allow",
      ".opencode/**": "allow"
    }
  },
  "agent": {
    "coder": {
      "description": "Primary coding agent with safety validation",
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "task": true
      }
    },
    "judge": {
      "description": "Safety judge - validates actions before execution",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "task_budget": 20,
      "temperature": 0.1,
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "task": false
      }
    }
  }
}
