{
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "guilds": {
        "*": {
          "requireMention": false,
          "channels": {
            "*": {
              "enabled": true
            }
          }
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "opencode": {
        "enabled": true
      },
      "minimax": {
        "enabled": true
      }
    }
  }
}