# OpenClaw Configuration
# Copy this to .env and fill in your values

# Discord Bot (required for Discord channel)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_discord_application_id_here

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=opencode-agent-secret-token

# OpenCode API Key (required for OpenCode models)
OPENCODE_API_KEY=your_opencode_api_key_here

# Git Configuration
# The repository to clone into /workspace at startup
# Leave empty to start with empty workspace
GIT_REPO_URL=https://github.com/YOUR_USERNAME/YOUR_REPO.git
GIT_USERNAME=your-github-username
GIT_EMAIL=your-email@example.com

# Network (optional)
# HTTP_PROXY=http://proxy:3128
# HTTPS_PROXY=http://proxy:3128
# NO_PROXY=localhost,127.0.0.1