# OpenClaw Configuration
# Copy this to .env and fill in your values

# Discord Bot (required for Discord channel)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_discord_application_id_here

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=opencode-agent-secret-token

# Model Configuration
OPENCODE_MODEL=opencode/minimax-m2.5-free

# Git Configuration (optional - for git operations)
GIT_REPO_URL=https://github.com/username/repo.git
GIT_USERNAME=your-github-username
GIT_EMAIL=your-email@example.com

# If using SSH for git:
# GIT_SSH_KEY=/data/keys/github SSH

# Network (optional)
# HTTP_PROXY=http://proxy:3128
# HTTPS_PROXY=http://proxy:3128
# NO_PROXY=localhost,127.0.0.1