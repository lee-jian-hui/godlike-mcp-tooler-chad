# Project Configuration
# Copy this to .env and fill in your values

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=property_market
DB_USER=postgres
DB_PASSWORD=your_password_here

# Data Sources (property portals, APIs)
PROPERTY_API_KEY=your_api_key_here
PROPERTY_API_URL=https://api.example.com

# MCP Server
MCP_PORT=3000
MCP_AUTH_TOKEN=your_mcp_auth_token

# Optional: Redis for caching
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: Airflow (for orchestrating pipelines)
AIRFLOW_PORT=8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=your_password